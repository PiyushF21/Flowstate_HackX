# InfraLens — Environment Variables
# Copy this file to .env and fill in your keys

# xAI / Grok API Key (for COGNOS, VIRA, COMMANDER, PRESCIENT, FLEET, FIELD_COPILOT, ORACLE)
XAI_API_KEY=your-grok-api-key

# Sarvam AI API Key (for VIRA TTS + FIELD_COPILOT voice responses)
SARVAM_API_KEY=your-sarvam-api-key

# Server config (optional)
# HOST=0.0.0.0
# PORT=8000
# DEBUG=true
# FRONTEND_ORIGIN=http://localhost:5173
